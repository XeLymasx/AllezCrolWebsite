---
const { } = Astro.props;
---

<div class="library-search">
    <div class="divider"></div>
    <div class="search-section">
        <input class="search-name" type="text" placeholder="[[SEARCH]] 输入名称..." id="searchName" />
        <input class="search-tag" type="text" placeholder="[[TAG]] 输入标签..." id="searchTag" />
    </div>
    <div class="divider"></div>
    <div class="library-grid" id="libraryGrid">
        <slot />
    </div>
    <div class="pagination" id="pagination"></div>
    <div class="divider"></div>
</div>

<script>
    const nameInput = document.getElementById('searchName') as HTMLInputElement;
    const tagInput = document.getElementById('searchTag') as HTMLInputElement;
    const grid = document.getElementById('libraryGrid');
    const pagination = document.getElementById('pagination');

    const itemsPerPage = 36;
    let currentPage = 1;
    let filteredBoxes: HTMLElement[] = [];

    function getAllBoxes() {
        return grid ? Array.from(grid.querySelectorAll('.ibox-wrap')) as HTMLElement[] : [];
    }

    function showPage(page: number) {
        currentPage = page;
        const start = (page - 1) * itemsPerPage;
        const end = start + itemsPerPage;

        filteredBoxes.forEach((box, index) => {
            box.style.display = index >= start && index < end ? 'block' : 'none';
        });

        renderPagination();
    }

    function renderPagination() {
        if (!pagination) return;
        const totalPages = Math.ceil(filteredBoxes.length / itemsPerPage);
        pagination.innerHTML = '';

        const prev = document.createElement('span');
        prev.textContent = '<';
        prev.className = 'page-btn' + (currentPage === 1 ? ' disabled' : '');
        prev.addEventListener('click', () => { if (currentPage > 1) showPage(currentPage - 1); });
        pagination.appendChild(prev);

        const num = document.createElement('span');
        num.textContent = `${currentPage}`;
        num.className = 'page-num';
        pagination.appendChild(num);

        const next = document.createElement('span');
        next.textContent = '>';
        next.className = 'page-btn' + (currentPage === totalPages ? ' disabled' : '');
        next.addEventListener('click', () => { if (currentPage < totalPages) showPage(currentPage + 1); });
        pagination.appendChild(next);
    }

    function filter() {
        const name = nameInput.value.toLowerCase();
        const tag = tagInput.value.toLowerCase();
        const all = getAllBoxes();

        filteredBoxes = all.filter((box) => {
            const title = box.querySelector('.ibox-title-text')?.textContent?.toLowerCase() || '';
            const tags = (box.dataset.tags || '').toLowerCase().split(',').map(t => t.trim());

            const matchName = name === '' || title.split(' ').some(word => word.startsWith(name));
            const matchTag = tag === '' || tags.some(t => t.startsWith(tag));

            return matchName && matchTag;
        });

        all.forEach(box => box.style.display = 'none');
        currentPage = 1;
        showPage(1);
    }

    nameInput?.addEventListener('input', filter);
    tagInput?.addEventListener('input', filter);

    filter();
</script>

<style lang="scss">
  @font-face {
    font-family: 'OCR-A BT';
    src: url('/fonts/OCR-a___.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .library-search {
    .divider {
      width: 100vw;
      height: 3px;
      background-color: #000000;
      margin-left: calc(-50vw + 50%);
    }

    .search-section {
      display: flex;
      gap: 16px;
      padding: 16px 40px;

      input {
        flex: 1;
        background: transparent;
        border: 2px solid #000000;
        outline: none;
        font-family: 'OCR-A BT', monospace;
        font-size: 0.85rem;
        color: #000;
        padding: 10px 16px;
        transition: box-shadow 0.3s ease;

        &::placeholder {
          color: rgba(0, 0, 0, 0.4);
          letter-spacing: 1px;
        }

        &:focus {
          border-color: #cc0000
        }
      }
    }

    .library-grid {
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 20px;
      padding: 32px 40px;
      box-sizing: border-box;

    }

    .pagination {
      display: flex;
      gap: 12px;
      justify-content: center;
      padding: 24px 0;
      font-family: 'OCR-A BT', monospace;
      font-size: 0.9rem;

      .page-btn {
        cursor: pointer;
        color: #000;
        transition: color 0.2s ease;

        &:hover {
          color: #cc0000;
        }

        &.active {
          color: #cc0000;
          font-weight: bold;
        }
      }
    }

    .page-num {
      color: #000000;
      font-family: 'OCR-A BT', monospace;
      font-size: 0.9rem;
    }

    .disabled {
      color: #cccccc;
      cursor: not-allowed;
    }
  }
</style>