---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title}>
    <style lang="scss">
      @font-face {
        font-family: 'OCR-A BT';
        src: url('/fonts/OCR-a___.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
      }

      :global(*) {
        font-family: 'OCR-A BT', monospace;
      }
    </style>
    <slot />
</BaseLayout>
