---
const { title, image, href = "#" } = Astro.props;
const truncated = title ? title.slice(0, 10) : "";
---

<a class="idxbox-wrap" href={href}>
    <div class="idxbox-image">
        <img src={image} alt={truncated} />
    </div>
    <div class="idxbox-title">
        <div class="idxbox-title-bg"></div>
        <span class="idxbox-title-text">{truncated}</span>
    </div>
</a>

<style is:global lang="scss">
  .idxbox-wrap {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 180px;
    cursor: pointer;
    transition: transform 0.3s ease;

    &:hover {
      transform: scale(1.05);

      .idxbox-title-bg {
        transform: scaleX(1) !important;
      }

      .idxbox-title-text {
        color: #ffffff !important;
      }
    }

    .idxbox-image {
      width: 100%;
      aspect-ratio: 3 / 4;
      overflow: hidden;
      background-color: #ffffff;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
    }

    .idxbox-title {
      position: relative;
      padding: 8px 12px;
      text-align: center;
      overflow: hidden;

      .idxbox-title-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #1a1a1a;
        transform: scaleX(0);
        transform-origin: right center;
        transition: transform 0.3s ease !important;
        animation: none !important;
        z-index: 0;
      }

      .idxbox-title-text {
        position: relative;
        z-index: 1;
        color: #000000;
        font-size: 0.9rem;
        font-family: 'OCR-A BT', monospace;
        letter-spacing: 1px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        transition: color 0.3s ease;
      }
    }
  }
</style>