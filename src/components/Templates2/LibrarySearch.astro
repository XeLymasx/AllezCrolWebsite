---
const { } = Astro.props;
---

<div class="library-search">
    <div class="divider"></div>
    <div class="search-section">
        <input class="search-name" type="text" placeholder="[[SEARCH]] 输入名称..." id="searchName" />
        <input class="search-tag" type="text" placeholder="[[TAG]] 输入标签..." id="searchTag" />
    </div>
    <div class="divider"></div>
    <div class="library-grid" id="libraryGrid">
        <slot />
    </div>
    <div class="divider"></div>
</div>

<script>
    const nameInput = document.getElementById('searchName') as HTMLInputElement;
    const tagInput = document.getElementById('searchTag') as HTMLInputElement;
    const grid = document.getElementById('libraryGrid');
    const boxes = grid ? Array.from(grid.querySelectorAll('.ibox-wrap')) : [];

    function filter() {
        const name = nameInput.value.toLowerCase();
        const tag = tagInput.value.toLowerCase();

        boxes.forEach((box) => {
            const el = box as HTMLElement;
            const title = el.querySelector('.ibox-title-text')?.textContent?.toLowerCase() || '';
            const tags = (el.dataset.tags || '').toLowerCase();

            const matchName = name === '' || title.includes(name);
            const matchTag = tag === '' || tags.includes(tag);

            el.style.display = matchName && matchTag ? 'block' : 'none';
        });
    }

    nameInput?.addEventListener('input', filter);
    tagInput?.addEventListener('input', filter);
</script>

<style lang="scss">
  @font-face {
    font-family: 'OCR-A BT';
    src: url('/fonts/OCR-a___.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  .library-search {
    .divider {
      width: 100vw;
      height: 3px;
      background-color: #000000;
      margin-left: calc(-50vw + 50%);
    }

    .search-section {
      display: flex;
      gap: 16px;
      padding: 16px 40px;

      input {
        flex: 1;
        background: transparent;
        border: 2px solid #000000;
        outline: none;
        font-family: 'OCR-A BT', monospace;
        font-size: 0.85rem;
        color: #000;
        padding: 10px 16px;
        transition: box-shadow 0.3s ease;

        &::placeholder {
          color: rgba(0, 0, 0, 0.4);
          letter-spacing: 1px;
        }

        &:focus {
          border-color: #cc0000
        }
      }
    }

    .library-grid {
      display: grid;
      grid-template-columns: repeat(9, 1fr);
      gap: 20px;
      padding: 32px 40px;
    }
  }
</style>